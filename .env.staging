# Staging environment configuration
VUE_APP_ENVIRONMENT=staging
VUE_APP_BASE_API=/api
VUE_APP_ZLMEDIAKIT_SERVICE_IP=your-staging-host
VUE_APP_ZLMEDIAKIT_IS_SSL=true
VUE_APP_ZLMEDIAKIT_HTTP_PORT=your-staging-http-port
VUE_APP_ZLMEDIAKIT_HTTP_SECRET=your-staging-secret
VUE_APP_ZLMEDIAKIT_RTMP_PORT=your-staging-rtmp-port
VUE_APP_FAKE_LOGIN=false
